<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background">

    <!-- Modern Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:padding="10dp"
            android:background="@drawable/quiz_surface_bg"
            android:elevation="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="21sp"
            android:textStyle="bold"
            android:textColor="#FF2D0C6E"
            android:gravity="center"
            android:fontFamily="sans-serif-black" />

        <Space
            android:layout_width="44dp"
            android:layout_height="44dp" />

    </LinearLayout>

    <!-- Banner Image -->
    <ImageView
        android:layout_width="260dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:adjustViewBounds="true"
        android:contentDescription="Games"
        android:scaleType="fitCenter"
        android:src="@drawable/games_content"
        android:layout_marginBottom="4dp" />

    <!-- Game Option Cards -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="28dp">

            <!-- Animal Quiz Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_animal_quiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#00000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp"
                    android:background="@drawable/game_card_quiz_bg">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/alphabets"
                        android:scaleType="centerCrop"
                        android:background="@drawable/quiz_surface_bg"
                        android:padding="3dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A-Z Alphabet Quiz"
                            android:textSize="21sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFFFF"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Learn the alphabet from A to Z!"
                            android:textSize="13sp"
                            android:textColor="#E8FFFFFF"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textSize="22sp"
                        android:textColor="#FFFFFFFF"
                        android:layout_marginStart="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Phonics Matching Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_phonics_matching"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#00000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp"
                    android:background="@drawable/game_card_phonics_bg">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/phonics_matching_icon"
                        android:scaleType="centerCrop"
                        android:background="@drawable/quiz_surface_bg"
                        android:padding="3dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phonics Matching"
                            android:textSize="21sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFFFF"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Match letters to pictures!"
                            android:textSize="13sp"
                            android:textColor="#E8FFFFFF"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textSize="22sp"
                        android:textColor="#FFFFFFFF"
                        android:layout_marginStart="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Memory Cards Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_memory_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#00000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp"
                    android:background="@drawable/game_card_memory_bg">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/memory_card_icon"
                        android:scaleType="centerCrop"
                        android:background="@drawable/quiz_surface_bg"
                        android:padding="3dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Memory Cards"
                            android:textSize="21sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFFFF"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Flip and find pairs!"
                            android:textSize="13sp"
                            android:textColor="#E8FFFFFF"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textSize="22sp"
                        android:textColor="#FFFFFFFF"
                        android:layout_marginStart="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>


