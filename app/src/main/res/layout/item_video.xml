<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/transparent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/video_item_bg"
        android:padding="16dp">

        <!-- Video Icon / Thumbnail Area -->
        <View
            android:id="@+id/video_icon_container"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="@drawable/ic_learning"
            android:gravity="center" />

        <!-- Play Icon Overlay -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="18dp"
            android:src="@android:drawable/ic_media_play"
            android:tint="#FFFB7185" />

        <!-- Video Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/video_icon_container"
            android:layout_marginStart="16dp"
            android:layout_toStartOf="@id/play_arrow"
            android:orientation="vertical"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/video_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FF0F172A"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/video_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="13sp"
                android:textColor="#FF64748B"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Play Arrow -->
        <ImageView
            android:id="@+id/play_arrow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:background="@drawable/quiz_surface_bg"
            android:padding="8dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="#FF3B82F6" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>