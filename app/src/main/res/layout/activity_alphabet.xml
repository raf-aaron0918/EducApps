<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:background="@android:color/transparent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:padding="10dp"
            android:background="@drawable/quiz_surface_bg"
            android:elevation="4dp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Space
            android:layout_width="44dp"
            android:layout_height="44dp" />

    </LinearLayout>

    <ImageView
        android:layout_width="260dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:adjustViewBounds="true"
        android:contentDescription="Alphabets"
        android:scaleType="fitCenter"
        android:src="@drawable/alphabets_content" />

    <TextView
        android:id="@+id/progress_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Letter 1 of 26"
        android:textSize="16sp"
        android:textColor="#E0FFFFFF"
        android:fontFamily="sans-serif"
        android:layout_marginTop="2dp"
        android:letterSpacing="-0.01" />

    <!-- Main Content Area -->
    <RelativeLayout
        android:id="@+id/main_content_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="14dp">

        <!-- Main Card Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Main Alphabet Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/alphabet_card_main"
                android:layout_width="340dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/transparent">

                <!-- Card Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="22dp"
                    android:minHeight="440dp"
                    android:background="@drawable/learn_surface_glass">

                    <!-- Large Letter -->
                    <TextView
                        android:id="@+id/letter_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A"
                        android:textSize="72sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-black"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp"
                        android:letterSpacing="0"
                        android:shadowColor="#66000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="4" />


                    <!-- Image Circle -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="164dp"
                        android:layout_height="164dp"
                        app:cardCornerRadius="82dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/learn_image_frame">

                        <ImageView
                            android:id="@+id/alphabet_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/a"
                            android:scaleType="centerInside"
                            android:adjustViewBounds="true"
                            android:contentDescription="Alphabet Image" />

                    </androidx.cardview.widget.CardView>

                    <!-- Word Text -->
                    <TextView
                        android:id="@+id/word_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="for Apple"
                        android:textSize="26sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="10dp"
                        android:paddingHorizontal="15dp"
                        android:ellipsize="none"
                        android:scrollHorizontally="false"
                        android:singleLine="false"
                        android:shadowColor="#66000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="4"
                        android:letterSpacing="-0.03" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </RelativeLayout>

    <!-- Compact Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="10dp"
        android:background="@android:color/transparent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swipe left/right to navigate"
            android:textSize="13sp"
            android:textColor="#FF000000"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/main_menu_chip"
            android:letterSpacing="-0.01" />

    </LinearLayout>

</LinearLayout>
