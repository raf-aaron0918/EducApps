<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Modern Header Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/quiz_surface_bg"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:background="@android:color/transparent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="A-Z Alphabet Quiz"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FF2D0C6E"
                android:gravity="center"
                android:fontFamily="sans-serif-black" />

            <ImageView
                android:id="@+id/restart_button"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:padding="8dp"
                android:background="@android:color/transparent"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Quiz Stats Row -->
        <LinearLayout
            android:id="@+id/quiz_stats_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/quiz_score_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Score: 0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF0F766E"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/quiz_surface_bg"
                android:elevation="2dp" />

            <TextView
                android:id="@+id/quiz_high_score_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Best: 0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF7C3AED"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/quiz_surface_bg"
                android:elevation="2dp" />

            <TextView
                android:id="@+id/quiz_wrong_left_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Lives: 10"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFB91C1C"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/quiz_surface_bg"
                android:elevation="2dp" />

        </LinearLayout>

        <!-- Memory Stats Row (hidden by default) -->
        <LinearLayout
            android:id="@+id/memory_stats_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:background="@drawable/quiz_surface_bg"
            android:padding="10dp"
            android:elevation="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/score_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Score: 0"
                android:textSize="15sp"
                android:textColor="#FF1976D2"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/rounded_white_bg"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/moves_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Moves: 0"
                android:textSize="15sp"
                android:textColor="#FFF57C00"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/rounded_white_bg"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Main Content Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:background="@drawable/quiz_surface_bg"
            android:elevation="4dp">

            <!-- Question Text -->
            <TextView
                android:id="@+id/question_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What starts with this letter?"
                android:textSize="19sp"
                android:textColor="#FFFFFFFF"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:padding="12dp"
                android:background="@drawable/game_card_phonics_bg"
                android:layout_marginBottom="12dp" />

            <!-- Letter Picture Display -->
            <ImageView
                android:id="@+id/animal_emoji"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/a"
                android:contentDescription="Letter quiz image"
                android:scaleType="centerInside"
                android:background="@drawable/quiz_surface_bg"
                android:elevation="8dp"
                android:layout_marginBottom="12dp" />

            <!-- Memory Game Grid -->
            <ScrollView
                android:id="@+id/memory_game_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <GridLayout
                        android:id="@+id/memory_game_grid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="4"
                        android:rowCount="4"
                        android:alignmentMode="alignBounds"
                        android:useDefaultMargins="true" />

                </LinearLayout>
            </ScrollView>

            <!-- Answer Buttons -->
            <LinearLayout
                android:id="@+id/quiz_buttons_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/answer_btn_1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp"
                    android:text="Option 1"
                    android:textColor="#FF0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/quiz_answer_button" />

                <Button
                    android:id="@+id/answer_btn_2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp"
                    android:text="Option 2"
                    android:textColor="#FF0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/quiz_answer_button" />

                <Button
                    android:id="@+id/answer_btn_3"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp"
                    android:text="Option 3"
                    android:textColor="#FF0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/quiz_answer_button" />

                <Button
                    android:id="@+id/answer_btn_4"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Option 4"
                    android:textColor="#FF0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/quiz_answer_button" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>

