<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background">

<!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="#F0F0F0"
            android:layout_marginEnd="12dp"
            android:contentDescription="Go back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Development Team"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

    <!-- Main Content with ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Developers Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

<LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:orientation="vertical"
                     android:padding="20dp">

                     <TextView
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:text="Development Team"
                         android:textSize="18sp"
                         android:textStyle="bold"
                         android:textColor="#333333"
                         android:layout_marginBottom="16dp" />

                     <!-- Developer 1 -->
                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:orientation="horizontal"
                         android:padding="12dp"
                         android:background="@drawable/rounded_background"
                         android:backgroundTint="#F8F9FA"
                         android:layout_marginBottom="16dp"
                         android:gravity="center_vertical">

                         <ImageView
                             android:id="@+id/developer1_photo"
                             android:layout_width="70dp"
                             android:layout_height="70dp"
                             android:layout_marginEnd="16dp"
                             android:clickable="true"
                              android:focusable="true"
                              android:src="@drawable/dela_rosa"
                             android:background="@drawable/circular_button"
                             android:backgroundTint="#E3F2FD"
                             android:padding="8dp"
                             android:scaleType="centerCrop" />

                         <LinearLayout
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_weight="1"
                             android:orientation="vertical">

                             <TextView
                                 android:id="@+id/developer1_name"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Rafael Aaron Dela Rosa"
                                 android:textSize="16sp"
                                 android:textStyle="bold"
                                 android:textColor="#333333" />

                             <TextView
                                 android:id="@+id/developer1_branch"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="BS Computer Science"
                                 android:textSize="13sp"
                                 android:textColor="#666666"
                                 android:layout_marginTop="4dp" />

                         </LinearLayout>

                     </LinearLayout>

                     <!-- Developer 2 -->
                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:orientation="horizontal"
                         android:padding="12dp"
                         android:background="@drawable/rounded_background"
                         android:backgroundTint="#F8F9FA"
                         android:layout_marginBottom="16dp"
                         android:gravity="center_vertical">

                         <ImageView
                             android:id="@+id/developer2_photo"
                             android:layout_width="70dp"
                             android:layout_height="70dp"
                             android:layout_marginEnd="16dp"
                             android:clickable="true"
                              android:focusable="true"
                              android:src="@drawable/mendoza"
                             android:background="@drawable/circular_button"
                             android:backgroundTint="#E3F2FD"
                             android:padding="8dp"
                             android:scaleType="centerCrop" />

                         <LinearLayout
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_weight="1"
                             android:orientation="vertical">

                             <TextView
                                 android:id="@+id/developer2_name"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="John Patrick Mendoza"
                                 android:textSize="16sp"
                                 android:textStyle="bold"
                                 android:textColor="#333333" />

                             <TextView
                                 android:id="@+id/developer2_branch"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="BS Computer Science"
                                 android:textSize="13sp"
                                 android:textColor="#666666"
                                 android:layout_marginTop="4dp" />

                         </LinearLayout>

                     </LinearLayout>

                     <!-- Developer 3 -->
                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:orientation="horizontal"
                         android:padding="12dp"
                         android:background="@drawable/rounded_background"
                         android:backgroundTint="#F8F9FA"
                         android:layout_marginBottom="16dp"
                         android:gravity="center_vertical">

                         <ImageView
                             android:id="@+id/developer3_photo"
                             android:layout_width="70dp"
                             android:layout_height="70dp"
                             android:layout_marginEnd="16dp"
                             android:clickable="true"
                              android:focusable="true"
                              android:src="@drawable/silvan"
                             android:background="@drawable/circular_button"
                             android:backgroundTint="#E3F2FD"
                             android:padding="8dp"
                             android:scaleType="centerCrop" />

                         <LinearLayout
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_weight="1"
                             android:orientation="vertical">

                             <TextView
                                 android:id="@+id/developer3_name"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Klein Silvan"
                                 android:textSize="16sp"
                                 android:textStyle="bold"
                                 android:textColor="#333333" />

                             <TextView
                                 android:id="@+id/developer3_branch"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="BS Computer Science"
                                 android:textSize="13sp"
                                 android:textColor="#666666"
                                 android:layout_marginTop="4dp" />

                         </LinearLayout>

                     </LinearLayout>

                     <!-- Developer 4 -->
                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:orientation="horizontal"
                         android:padding="12dp"
                         android:background="@drawable/rounded_background"
                         android:backgroundTint="#F8F9FA"
                         android:gravity="center_vertical">

                         <ImageView
                             android:id="@+id/developer4_photo"
                             android:layout_width="70dp"
                             android:layout_height="70dp"
                             android:layout_marginEnd="16dp"
                             android:clickable="true"
                              android:focusable="true"
                              android:src="@drawable/esguerra"
                             android:background="@drawable/circular_button"
                             android:backgroundTint="#E3F2FD"
                             android:padding="8dp"
                             android:scaleType="centerCrop" />

                         <LinearLayout
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_weight="1"
                             android:orientation="vertical">

                             <TextView
                                 android:id="@+id/developer4_name"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Jo Mari Esguerra"
                                 android:textSize="16sp"
                                 android:textStyle="bold"
                                 android:textColor="#333333" />

                             <TextView
                                 android:id="@+id/developer4_branch"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="BS Computer Science"
                                 android:textSize="13sp"
                                 android:textColor="#666666"
                                 android:layout_marginTop="4dp" />

                         </LinearLayout>

                     </LinearLayout>

                 </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
