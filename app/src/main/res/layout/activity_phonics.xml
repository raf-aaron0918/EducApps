<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/background">

    <!-- Modern Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/game_card_phonics_bg"
        android:padding="14dp"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:background="@drawable/quiz_surface_bg" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Phonics Matching"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:fontFamily="sans-serif-black"
            android:layout_marginEnd="40dp" />

    </LinearLayout>

    <!-- Stats & Info Panel -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/quiz_surface_bg"
        android:elevation="3dp">

        <!-- Level + Score Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Level 1/4"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FF6C63FF"
                android:padding="6dp"
                android:background="@drawable/rounded_white_bg" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score: 0"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFF5E85"
                android:padding="6dp"
                android:background="@drawable/rounded_white_bg" />

        </LinearLayout>

        <!-- Difficulty Label -->
        <TextView
            android:id="@+id/tvDifficulty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Easy: Letters in order"
            android:textSize="13sp"
            android:textStyle="italic"
            android:textColor="#FF7B72E9"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginBottom="6dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:progress="0"
            android:max="5"
            android:progressTint="#FF6C63FF"
            android:progressBackgroundTint="#FFDDD8FF" />

        <!-- Instruction -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Drag letters to their matching pictures!"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF44A1F6"
            android:gravity="center" />

    </LinearLayout>

    <!-- Game Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp">

        <!-- Letters Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="5dp"
            android:background="@drawable/phonics_panel_bg"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LETTERS"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/phonics_section_header_letters"
                android:textColor="#FFFFFFFF"
                android:padding="10dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLetters"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Pictures Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="5dp"
            android:background="@drawable/phonics_panel_bg"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PICTURES"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/phonics_section_header_pictures"
                android:textColor="#FFFFFFFF"
                android:padding="10dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvObjects"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:clipToPadding="false" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

