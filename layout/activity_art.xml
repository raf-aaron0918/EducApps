<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/toolbar_modern"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:id="@+id/art_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center_vertical"
            android:text="Canvas"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_save"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Save artwork"
            android:padding="9dp"
            android:src="@drawable/ic_save" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/drawing_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <com.marwadiuniversity.abckids.GlitterDrawingView
            android:id="@+id/drawing_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/art_canvas_background" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottom_control_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/surface_panel_modern"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="Brush"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/brush_size_seekbar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:max="25"
                android:progress="5" />

            <Button
                android:id="@+id/glitter_button"
                android:layout_width="74dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/action_button_secondary_modern"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="Glitter"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/erase_button"
                android:layout_width="64dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/action_button_secondary_modern"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="Erase"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/clear_button"
                android:layout_width="64dp"
                android:layout_height="36dp"
                android:background="@drawable/action_button_secondary_modern"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="Clear"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:alignmentMode="alignBounds"
                android:columnCount="22"
                android:rowCount="1"
                android:useDefaultMargins="false">

                <Button android:id="@+id/color_red" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_blue" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_green" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_yellow" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_purple" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_orange" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_pink" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_cyan" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_black" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_white" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_gray" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_magenta" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_brown" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_gold" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_spring_green" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_deep_pink" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_royal_blue" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_tomato" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_dark_orchid" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_lime_green" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_hot_pink" style="@style/ColorSwatchButton" />
                <Button android:id="@+id/color_dark_turquoise" style="@style/ColorSwatchButton" />
            </GridLayout>
        </HorizontalScrollView>
    </LinearLayout>
</LinearLayout>
